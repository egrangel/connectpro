# PostgreSQL connection string (dev and production).
# Free options for dev: Prisma Postgres, Neon, Supabase, or a local install.
DATABASE_URL="postgresql://user:password@localhost:5432/connect"

# Vercel Blob storage for uploaded photos (production/Vercel).
# Leave unset in development to store uploads on local disk (public/uploads/).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Used only by `npm run db:seed` to create the first admin account.
# There is NO self-service path to an admin account — registration always creates USER.
SEED_ADMIN_EMAIL="admin@connect.local"
SEED_ADMIN_PASSWORD="change-me"
