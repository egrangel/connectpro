# SQLite for local development. For production PostgreSQL use e.g.:
# DATABASE_URL="postgresql://user:password@localhost:5432/connect"
DATABASE_URL="file:./dev.db"

# Used only by `npm run db:seed` to create the first admin account.
# There is NO self-service path to an admin account — registration always creates USER.
SEED_ADMIN_EMAIL="admin@connect.local"
SEED_ADMIN_PASSWORD="change-me"
